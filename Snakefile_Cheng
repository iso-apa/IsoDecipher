import os
import subprocess

os.makedirs("logs", exist_ok=True)
os.makedirs("results/panel", exist_ok=True)
os.makedirs("results/counts", exist_ok=True)
os.makedirs("results/h5ad", exist_ok=True)
os.makedirs("results/insert_size/Cheng", exist_ok=True)

GTF     = "/Volumes/Lexar/reference/hg38/Homo_sapiens.GRCh38.115.gtf"
GENES   = "results/gene_lists/gene_list_Cheng.txt"

INCLUDE_NMD = config.get("include_nmd", False)
TOLERANCE   = config.get("tolerance", 125)

SAMPLES = ['exp97', 'exp105', 'exp106']  # exp93 excluded (unpublished)
print(f"[IsoDecipher] Found samples: {SAMPLES}")

MATRIX_DIRS = {
    s: f"data/samples/Cheng/{s}/filtered_feature_bc_matrix"
    for s in SAMPLES
}

rule all:
    input:
        "results/h5ad/master_mosaic_combined_Cheng_PanelKDE.h5ad"

rule make_gene_list:
    input:
        matrices = expand(
            "/Volumes/Lexar/Cheng/{sample}/filtered_feature_bc_matrix/matrix.mtx.gz",
            sample=SAMPLES
        )
    output:
        genes = "results/gene_lists/gene_list_Cheng.txt"
    log:
        "logs/make_gene_list.log"
    run:
        import subprocess, os
        tmp_lists = []
        for sample in SAMPLES:
            tmp = f"results/gene_lists/gene_list_{sample}.txt"
            subprocess.run([
                "python", "IsoDecipher/scripts/make_gene_list.py",
                "--matrix", f"/Volumes/Lexar/Cheng/{sample}/filtered_feature_bc_matrix",
                "--out", tmp,
                "--min-cells", "3"
            ], check=True)
            tmp_lists.append(tmp)
        all_genes = set()
        for f in tmp_lists:
            with open(f) as fh:
                all_genes.update(line.strip() for line in fh if line.strip())
        with open(output.genes, 'w') as fh:
            fh.write('\n'.join(sorted(all_genes)) + '\n')
        print(f"[make_gene_list] Union: {len(all_genes):,} genes from {len(SAMPLES)} samples")

rule build_panel:
    input:
        gtf   = GTF,
        genes = GENES
    output:
        panel = "results/panel/panel_features_Cheng.csv"
    log:
        "logs/build_panel.log"
    params:
        nmd_flag  = "--include-nmd" if INCLUDE_NMD else "",
        tolerance = TOLERANCE
    shell:
        """
        python IsoDecipher/scripts/build_panel_features.py \
            --gtf       {input.gtf} \
            --genes     {input.genes} \
            --out       {output.panel} \
            --tolerance {params.tolerance} \
            {params.nmd_flag} \
            2> {log}
        """

rule validate_insert_size:
    input:
        bam   = "/Volumes/Lexar/Cheng/{sample}_possorted_genome_bam.bam",
        panel = "results/panel/panel_features_Cheng.csv"  # 改回 panel
    output:
        plot   = "results/insert_size/Cheng/{sample}_insert_size_dist.png",
        lookup = "results/insert_size/Cheng/{sample}_insert_size_dist_lookup.json"
    log:
        "logs/{sample}_validate_insert_size.log"
    shell:
        """
        python IsoDecipher/scripts/validate_insert_size.py \
            --bam     {input.bam} \
            --panel   {input.panel} \
            --out     {output.plot} \
            --n-reads 200000 \
            2> {log}
        """

rule assign_reads:
    input:
        panel    = "results/panel/panel_features_Cheng.csv",
        barcodes = "/Volumes/Lexar/Cheng/{sample}/filtered_feature_bc_matrix/barcodes.tsv.gz",
        lookup   = "results/insert_size/Cheng/{sample}_insert_size_dist_lookup.json"  # panel KDE
    output:
        "results/counts/{sample}_isoform_count_Cheng.csv"
    log:
        "logs/{sample}_assign_reads.log"
    shell:
        """
        python IsoDecipher/scripts/assign_reads.py \
            --bam /Volumes/Lexar/Cheng/{wildcards.sample}_possorted_genome_bam.bam \
            --panel {input.panel} \
            --barcodes {input.barcodes} \
            --insert-size-lookup {input.lookup} \
            --out {output} \
            2> {log}
        """

rule integrate:
    input:
        expand("results/counts/{sample}_isoform_count_Cheng.csv", sample=SAMPLES),
        panel = "results/panel/panel_features_Cheng.csv"
    output:
        "results/h5ad/master_mosaic_combined_Cheng_PanelKDE.h5ad"
    log:
        "logs/integrate.log"
    params:
        samples = lambda wildcards: " ".join(SAMPLES)
    shell:
        """
        python IsoDecipher/scripts/integrate_samples.py \
            --samples {params.samples} \
            --data_dir /Volumes/Lexar/Cheng \
            --iso_dir results/counts \
            --suffix _isoform_count_Cheng.csv \
            --panel results/panel/panel_features_Cheng.csv \
            --out {output} \
            2> {log}
        """