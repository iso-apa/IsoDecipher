import os
import subprocess

os.makedirs("logs", exist_ok=True)
os.makedirs("results/counts", exist_ok=True)

GTF = "data/Homo_sapiens.GRCh38.115.gtf"
GENES = "data/gene_list_expanded.txt"

# Optional: include NMD transcripts in panel
# Override with: snakemake --config include_nmd=True
INCLUDE_NMD = config.get("include_nmd", False)

# Auto-detect samples from GCS
SAMPLES = ['exp93', 'exp97', 'exp105', 'exp106']
print(f"[IsoDecipher] Found samples: {SAMPLES}")

rule all:
    input:
        "results/master_mosaic_combined_expanded_350.h5ad" 

rule build_panel:
    input:
        gtf = GTF,
        genes = GENES
    output:
        panel = "results/panel_features_expanded.csv"
    log:
        "logs/build_panel.log"
    params:
        nmd_flag = "--include-nmd" if INCLUDE_NMD else ""
    shell:
        """
        python IsoDecipher/scripts/build_panel_features.py \
            --gtf {input.gtf} \
            --genes {input.genes} \
            --out {output.panel} \
            --tolerance 10 \
            {params.nmd_flag} \
            2> {log}
        """

rule assign_reads:
    input:
        panel = "results/panel_features_expanded.csv",
        barcodes = "data/samples/Cheng/{sample}/filtered_feature_bc_matrix/barcodes.tsv.gz"
    output:
        "results/counts/{sample}_isoform_count_expanded.csv"
    log:
        "logs/{sample}_assign_reads.log"
    shell:
        """
        python IsoDecipher/scripts/assign_reads.py \
            --bam /Volumes/Lexar/bam/{wildcards.sample}_possorted_genome_bam.bam \
            --panel {input.panel} \
            --barcodes {input.barcodes} \
            --out {output} \
            --window 350 \
            2> {log}
        """

rule integrate:
    input:
        expand("results/counts/{sample}_isoform_count_expanded.csv", sample=SAMPLES)
    output:
        "results/master_mosaic_combined_expanded_350.h5ad"
    log:
        "logs/integrate.log"
    params:
        samples = lambda wildcards: " ".join(SAMPLES)
    shell:
        """
        python IsoDecipher/scripts/integrate_samples.py \
            --samples {params.samples} \
            --data_dir data/samples/Cheng \
            --iso_dir results/counts \
            --suffix _isoform_count_expanded.csv \
            --out {output} \
            2> {log}
        """